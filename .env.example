# Noticeify — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── Backend API ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/noticeify

# IP anonymization — set to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=change-me-in-production

# Optional geo lookup configuration for consent ingestion
GEOIP_ENDPOINT=https://ipapi.co
GEO_LOOKUP_TIMEOUT_MS=1200

# Set to 'true' if running behind Nginx, Cloudflare, or any reverse proxy
TRUST_PROXY=false

# Comma-separated list of allowed CORS origins (or * for development)
CORS_ORIGINS=https://www.39dollarglasses.com,https://www.ocusafe.com

# ── Database pool ──────────────────────────────────────────────────────────
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=10000
DB_CONN_TIMEOUT_MS=5000

# Scanner worker tuning
SCANNER_POLL_MS=5000
SCANNER_STALE_RUNNING_MINUTES=30
